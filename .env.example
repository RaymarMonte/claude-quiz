# Notion internal integration token (secret — never commit the real .env)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filled in by `npm run setup` (one-time DB creation). IDs of the two databases.
TOPICS_DB_ID=
QUESTION_BANK_DB_ID=
# Internal property ID of the Question Bank Title property (for titles-only dedup reads).
QUESTION_TITLE_PROP_ID=

# Parent page under which `npm run setup` creates the two databases.
# Share this page with the integration first. Grab the ID from the page URL.
NOTION_PARENT_PAGE_ID=

# Port the MCP server listens on (Tailscale Funnel forwards to this).
PORT=8787
