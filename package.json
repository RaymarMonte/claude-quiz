{
  "name": "claude-quiz",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous spaced-repetition quiz system (v5) — custom MCP server bridging Claude chat to two Notion databases.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "tsx src/setup.ts",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@notionhq/client": "^2.2.15",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
